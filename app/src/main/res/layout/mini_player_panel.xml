<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayerCard"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="0dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false"
    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.TopRounded"
    app:cardBackgroundColor="#991A1A1A"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground"
    android:foreground="?attr/selectableItemBackground">

<FrameLayout
android:layout_width="match_parent"
android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivMiniCover"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_placeholder_cover"
        android:contentDescription="Обложка трека"
        android:background="@drawable/bg_rounded_8dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvMiniTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Название трека"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvMiniArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Исполнитель"
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center">

        <com.example.audioplayer.view.CircularProgressButton
            android:id="@+id/btnPlayPauseProgress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ImageView
            android:id="@+id/ivPlayPauseIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Play/Pause"/>
    </FrameLayout>

</LinearLayout>
</FrameLayout>

    </com.google.android.material.card.MaterialCardView>